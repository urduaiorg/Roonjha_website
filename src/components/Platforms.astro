---
const platforms = [
  {
    id: 'urduai',
    tag: 'AI Literacy',
    name: 'Urdu AI',
    description: 'Pakistan\'s leading Urdu-language AI education platform. Social media, newsletter, mobile app, and workshops reaching the largest Urdu AI community in the world.',
    stat: '1M+ reach',
    url: 'https://urduai.org',
    wide: false,
  },
  {
    id: 'pakspeed',
    tag: 'Digital Infrastructure',
    name: 'PakSpeed',
    description: 'Pakistan\'s first community-owned internet speed monitoring network. Real connectivity data for digital equity advocacy and ISP accountability.',
    stat: '15K+ tests Week 1',
    url: 'https://pakspeed.com',
    wide: false,
  },
  {
    id: 'aiforedu',
    tag: 'AI in Education',
    name: 'AI for Edu',
    description: 'Independent AI tool reviews, policy resources, and implementation guidance for educators and institutions worldwide. Vendor-neutral. Evidence-based.',
    stat: null,
    url: 'https://aiforedu.ai',
    wide: false,
  },
  {
    id: 'wang',
    tag: 'Community Development & Social Enterprise',
    name: 'WANG / WALI / WIRE',
    description: 'Girls\' education, flood rehabilitation, rural digital literacy, and youth leadership — plus a women-led social enterprise turning traditional crafts into sustainable livelihoods through e-commerce. Fifty homes rebuilt after the 2022 floods. Pakistan\'s first rural innovation hub (WALI). Over a decade on the ground.',
    stat: '50 Homes Rebuilt · MIT Solve 2025 Semi-Finalist · Funded by ISOC, AVPN, Google.org, ADB',
    url: 'https://wang.org.pk',
    wide: true,
  },
  {
    id: 'aiviewer',
    tag: 'AI Media',
    name: 'AI Viewer',
    description: 'English-language AI news, tool breakdowns, and analysis for a global professional audience.',
    stat: null,
    url: 'https://aiviewer.ai',
    wide: false,
  },
];
---

<section class="platforms section" id="platforms">
  <div class="platforms__inner container">
    <div class="platforms__header reveal">
      <div class="platforms__header-left">
        <span class="eyebrow">Ecosystem</span>
        <h2>Five platforms.<br /><em>One ecosystem.</em></h2>
      </div>
      <p class="platforms__header-intro">
        Each platform serves a different community, a different language, a different need. Together, they form a connected infrastructure for AI inclusion that spans two continents.
      </p>
    </div>

    <div class="platforms__grid reveal-stagger">
      {platforms.map((p) => (
        <a
          href={p.url}
          class={`platform-card reveal ${p.wide ? 'platform-card--wide' : ''}`}
          target={p.url.startsWith('http') ? '_blank' : undefined}
          rel={p.url.startsWith('http') ? 'noopener noreferrer' : undefined}
        >
          <div class="platform-card__top-border" aria-hidden="true"></div>
          <div class="platform-card__icon" aria-hidden="true">
            {p.id === 'urduai' && (
              <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="4" y="4" width="32" height="32" rx="8" stroke="currentColor" stroke-width="1.5"/>
                <path d="M14 16v8c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2v-8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M12 14h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <circle cx="17" cy="21" r="1.25" fill="currentColor"/>
                <circle cx="23" cy="21" r="1.25" fill="currentColor"/>
                <path d="M18.5 24.5c.5.5 1.5 1 1.5 1s1-.5 1.5-1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
              </svg>
            )}
            {p.id === 'pakspeed' && (
              <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="20" cy="22" r="14" stroke="currentColor" stroke-width="1.5"/>
                <path d="M20 12v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M28.5 15l-1.4 1.4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M32 22h-2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M10 22h2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M11.5 15l1.4 1.4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M20 22l-6-8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <circle cx="20" cy="22" r="2" fill="currentColor"/>
              </svg>
            )}
            {p.id === 'aiforedu' && (
              <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M8 32V10a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v16a2 2 0 0 1-2 2H12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M8 32l4-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M14 14h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M14 18h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M14 22h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M30 12v18a2 2 0 0 1-2 2H12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" stroke-dasharray="3 3" opacity="0.4"/>
              </svg>
            )}
            {p.id === 'wang' && (
              <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="20" cy="12" r="4" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="10" cy="18" r="3" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="30" cy="18" r="3" stroke="currentColor" stroke-width="1.5"/>
                <path d="M14 28c0-3.3 2.7-6 6-6s6 2.7 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M6 30c0-2.2 1.8-4 4-4s4 1.8 4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M26 30c0-2.2 1.8-4 4-4s4 1.8 4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M20 34v-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.4"/>
                <path d="M13 31l-3-1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" opacity="0.3"/>
                <path d="M27 31l3-1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" opacity="0.3"/>
              </svg>
            )}
            {p.id === 'aiviewer' && (
              <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="6" y="8" width="28" height="20" rx="3" stroke="currentColor" stroke-width="1.5"/>
                <path d="M6 14h28" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="10" cy="11" r="1" fill="currentColor"/>
                <circle cx="14" cy="11" r="1" fill="currentColor"/>
                <circle cx="18" cy="11" r="1" fill="currentColor"/>
                <path d="M11 20h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M11 24h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <rect x="26" y="18" width="4" height="6" rx="1" stroke="currentColor" stroke-width="1.2"/>
                <path d="M16 32h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M20 28v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            )}
          </div>
          <span class="platform-card__tag">{p.tag}</span>
          <h3 class="platform-card__name">{p.name}</h3>
          <p class="platform-card__desc">{p.description}</p>
          {p.stat && <span class="platform-card__stat">{p.stat}</span>}
          <span class="platform-card__link">
            {p.url.startsWith('http') ? p.url.replace('https://', '') : 'Get in touch'}
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M4 12l8-8M5 4h7v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .platforms {
    background: var(--paper);
  }

  .platforms__header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: end;
    margin-bottom: 3.5rem;
  }

  .platforms__header h2 em {
    font-style: italic;
    font-weight: 300;
  }

  .platforms__header-intro {
    font-size: 1.0625rem;
    line-height: 1.85;
    color: var(--muted);
  }

  .platforms__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  /* Card */
  .platform-card {
    position: relative;
    background: #fff;
    border: 1px solid rgba(181, 169, 154, 0.15);
    border-radius: var(--radius);
    padding: 2.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    transition: background 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
    overflow: hidden;
  }

  .platform-card:hover {
    background: #fdfbf8;
    border-color: rgba(181, 169, 154, 0.3);
    box-shadow: 0 8px 32px rgba(13, 13, 13, 0.04);
  }

  .platform-card__top-border {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--rust);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .platform-card:hover .platform-card__top-border {
    transform: scaleX(1);
  }

  .platform-card--wide {
    grid-column: span 2;
  }

  /* Icon */
  .platform-card__icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--rust);
    margin-bottom: 0.35rem;
    transition: color 0.25s ease, transform 0.3s ease;
  }

  .platform-card__icon svg {
    width: 100%;
    height: 100%;
  }

  .platform-card:hover .platform-card__icon {
    color: var(--gold);
    transform: translateY(-2px);
  }

  .platform-card__tag {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
  }

  .platform-card__name {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--ink);
  }

  .platform-card__desc {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--muted);
    max-width: none;
  }

  .platform-card__stat {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--rust);
    margin-top: 0.25rem;
  }

  .platform-card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--rust);
    margin-top: auto;
    padding-top: 0.75rem;
    transition: gap 0.2s ease;
  }

  .platform-card:hover .platform-card__link {
    gap: 0.6rem;
  }

  @media (max-width: 1024px) {
    .platforms__header {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .platforms__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .platform-card--wide {
      grid-column: span 2;
    }
  }

  @media (max-width: 768px) {
    .platforms__grid {
      grid-template-columns: 1fr;
    }

    .platform-card--wide {
      grid-column: span 1;
    }
  }
</style>
