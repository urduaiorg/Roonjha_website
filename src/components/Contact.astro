---
const contactOptions = [
  { icon: 'mail', label: 'Email', value: 'hello@roonjha.com', href: 'mailto:hello@roonjha.com' },
  { icon: 'linkedin', label: 'LinkedIn', value: 'linkedin.com/in/qaisarroonjha', href: 'https://linkedin.com/in/qaisarroonjha' },
  { icon: 'globe', label: 'Urdu AI', value: 'urduai.org', href: 'https://urduai.org' },
];

const dropdownOptions = [
  'Platform Sponsorship/Partnership',
  'Funding/Development Partnership',
  'Media/Speaking/Interview',
  'Collaboration Proposal',
  'Other',
];
---

<section class="contact section" id="contact">
  <div class="contact__inner container">
    <div class="contact__left reveal">
      <h2 class="contact__heading">Let&rsquo;s build something that matters.</h2>
      <p class="contact__subtext">
        Tell me who you are and what you&rsquo;re working on. I respond personally &mdash; usually within 48 hours.
      </p>

      <div class="contact__options">
        {contactOptions.map((opt) => (
          <a href={opt.href} class="contact__option" target={opt.href.startsWith('http') ? '_blank' : undefined} rel={opt.href.startsWith('http') ? 'noopener noreferrer' : undefined}>
            <span class="contact__option-icon" aria-hidden="true">
              {opt.icon === 'mail' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              )}
              {opt.icon === 'linkedin' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
              )}
              {opt.icon === 'globe' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
              )}
            </span>
            <span class="contact__option-content">
              <span class="contact__option-label">{opt.label}</span>
              <span class="contact__option-value">{opt.value}</span>
            </span>
          </a>
        ))}
      </div>
    </div>

    <div class="contact__right reveal">
      <form id="contact-form" class="contact__form" action="https://formspree.io/f/PLACEHOLDER" method="POST">
        <div class="form__row">
          <div class="form__group">
            <label for="contact-name" class="form__label">Name</label>
            <input type="text" id="contact-name" name="name" required class="form__input" placeholder="Your full name" />
          </div>
          <div class="form__group">
            <label for="contact-email" class="form__label">Email</label>
            <input type="email" id="contact-email" name="email" required class="form__input" placeholder="you@example.com" />
          </div>
        </div>

        <div class="form__group">
          <label for="contact-org" class="form__label">Organisation</label>
          <input type="text" id="contact-org" name="organisation" class="form__input" placeholder="Your company or org" />
        </div>

        <div class="form__group">
          <label for="contact-type" class="form__label">I&rsquo;m reaching out about&hellip;</label>
          <select id="contact-type" name="type" required class="form__input form__select">
            <option value="" disabled selected>Select a topic</option>
            {dropdownOptions.map((opt) => (
              <option value={opt}>{opt}</option>
            ))}
          </select>
        </div>

        <div class="form__group">
          <label for="contact-message" class="form__label">Message</label>
          <textarea id="contact-message" name="message" required class="form__input form__textarea" rows="5" placeholder="Tell me about your project or proposal..."></textarea>
        </div>

        <button type="submit" class="btn btn-primary form__submit">
          Send Message
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>

        <div id="form-success" class="form__success" hidden>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
          <p>Thank you. I&rsquo;ll be in touch within 48 hours.</p>
        </div>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: data,
        headers: { Accept: 'application/json' },
      });

      if (res.ok) {
        form.reset();
        form.style.display = 'none';
        if (success) success.hidden = false;
      }
    } catch {
      // Silently handle — form will still work via normal POST
      form.submit();
    }
  });
</script>

<style>
  .contact {
    background: var(--paper);
  }

  .contact__inner {
    display: grid;
    grid-template-columns: 42% 1fr;
    gap: 4rem;
    align-items: start;
  }

  .contact__left {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact__heading {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
  }

  .contact__subtext {
    font-size: 1.0625rem;
    line-height: 1.85;
    color: var(--muted);
  }

  .contact__options {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1rem;
  }

  .contact__option {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border: 1px solid rgba(181, 169, 154, 0.15);
    border-radius: var(--radius);
    transition: border-color 0.25s ease, background 0.25s ease;
  }

  .contact__option:hover {
    border-color: rgba(181, 169, 154, 0.35);
    background: rgba(255, 255, 255, 0.5);
  }

  .contact__option-icon {
    color: var(--rust);
    flex-shrink: 0;
    display: flex;
  }

  .contact__option-content {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .contact__option-label {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--faint);
  }

  .contact__option-value {
    font-size: 0.9375rem;
    color: var(--ink);
    font-weight: 400;
  }

  /* Form */
  .contact__form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .form__group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form__label {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--muted);
  }

  .form__input {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    padding: 0.75rem 1rem;
    border: 1px solid rgba(181, 169, 154, 0.25);
    border-radius: var(--radius);
    background: #fff;
    color: var(--ink);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    width: 100%;
  }

  .form__input::placeholder {
    color: var(--faint);
  }

  .form__input:focus {
    outline: none;
    border-color: var(--rust);
    box-shadow: 0 0 0 3px rgba(191, 66, 16, 0.08);
  }

  .form__select {
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1.5L6 6.5L11 1.5' stroke='%236E6455' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 1rem center;
    padding-right: 2.5rem;
    cursor: pointer;
  }

  .form__textarea {
    resize: vertical;
    min-height: 120px;
  }

  .form__submit {
    width: 100%;
    justify-content: center;
    padding: 1rem;
    font-size: 0.9375rem;
    margin-top: 0.5rem;
  }

  .form__success {
    align-items: center;
    gap: 0.75rem;
    padding: 1.5rem;
    background: rgba(184, 145, 60, 0.08);
    border: 1px solid rgba(184, 145, 60, 0.2);
    border-radius: var(--radius);
    color: var(--ink);
    display: none;
  }

  .form__success:not([hidden]) {
    display: flex;
  }

  .form__success svg {
    color: var(--gold);
    flex-shrink: 0;
  }

  .form__success p {
    font-size: 0.9375rem;
    font-weight: 500;
    max-width: none;
  }

  @media (max-width: 1024px) {
    .contact__inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  @media (max-width: 768px) {
    .form__row {
      grid-template-columns: 1fr;
    }
  }
</style>
