---
const stats = [
  { value: '35', suffix: 'M+', label: 'Monthly Reach' },
  { value: '1', suffix: 'M+', label: 'AI Community' },
  { value: '5', suffix: '', label: 'Live Platforms' },
  { value: '3', suffix: '', label: 'Graduate Degrees' },
];
---

<section class="hero" id="hero">
  <div class="hero__inner container">
    <div class="hero__content hero-enter">
      <span class="eyebrow">AI Educator &middot; Founder &middot; Development Professional</span>
      <h1 class="hero__heading">
        The next billion<br />
        <em>deserve AI too.</em>
      </h1>
      <p class="hero__lead">
        I build the platforms and communities that make AI accessible to people the tech world forgot. Five platforms, two continents, one conviction.
      </p>
      <div class="hero__stats">
        {stats.map((stat) => (
          <div class="hero__stat">
            <span
              class="hero__stat-value"
              data-count={stat.value}
              data-suffix={stat.suffix}
            >
              0{stat.suffix}
            </span>
            <span class="hero__stat-label">{stat.label}</span>
          </div>
        ))}
      </div>
      <div class="hero__cta">
        <a href="#partner" class="btn btn-primary btn-arrow">
          Partner With Me
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="#story" class="btn btn-outline btn-arrow">
          Read the Story
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 3v10M4 9l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>

    <div class="hero__visual hero-enter" style="animation-delay: 0.25s;">
      <div class="hero__photo-wrapper">
        <div class="hero__photo-accent" aria-hidden="true"></div>
        <picture>
          <source srcset="/hero.webp" type="image/webp" />
          <img
            class="hero__photo"
            src="/Hero.jpg"
            alt="Qaisar Roonjha standing in green fields, wearing an Urdu AI polo shirt"
            width="2344"
            height="1320"
            loading="eager"
            fetchpriority="high"
          />
        </picture>
        <div class="hero__overlay"></div>
        <blockquote class="hero__quote">
          <p>&ldquo;The most important work in AI isn&rsquo;t building the next model &mdash; it&rsquo;s ensuring the next billion people know how to use it.&rdquo;</p>
          <cite>&mdash; Qaisar Roonjha</cite>
        </blockquote>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    padding-top: 5rem;
    padding-bottom: 3rem;
    overflow: hidden;
    position: relative;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3.5rem;
    align-items: center;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .hero__heading {
    line-height: 1.06;
  }

  .hero__heading em {
    font-style: italic;
    font-weight: 300;
    color: var(--rust);
  }

  .hero__lead {
    font-size: 1.0625rem;
    line-height: 1.85;
    color: var(--muted);
    max-width: 48ch;
  }

  /* Stats */
  .hero__stats {
    display: flex;
    gap: 0;
    border: 1px solid rgba(181, 169, 154, 0.25);
    border-radius: var(--radius);
    overflow: hidden;
    max-width: 520px;
    background: rgba(255, 255, 255, 0.4);
  }

  .hero__stat {
    flex: 1;
    padding: 1rem 0.75rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .hero__stat:not(:last-child) {
    border-right: 1px solid rgba(181, 169, 154, 0.25);
  }

  .hero__stat-value {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.2;
  }

  .hero__stat-label {
    font-size: 0.65rem;
    font-weight: 500;
    color: var(--faint);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    line-height: 1.3;
  }

  .hero__cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* Visual / Photo column */
  .hero__photo-wrapper {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .hero__photo-accent {
    position: absolute;
    top: -8px;
    right: -8px;
    bottom: -8px;
    left: -8px;
    border: 1px solid rgba(184, 145, 60, 0.15);
    border-radius: calc(var(--radius-lg) + 4px);
    pointer-events: none;
    z-index: -1;
  }

  .hero__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
    display: block;
    filter: contrast(1.04) saturate(0.92);
    min-height: 480px;
    transition: transform 8s ease;
  }

  .hero__photo-wrapper:hover .hero__photo {
    transform: scale(1.03);
  }

  .hero__overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 55%;
    background: linear-gradient(to top, rgba(13, 13, 13, 0.88) 0%, transparent 100%);
    pointer-events: none;
  }

  .hero__quote {
    position: absolute;
    bottom: 1.25rem;
    left: 1.25rem;
    right: 1.25rem;
    background: rgba(13, 13, 13, 0.65);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-left: 3px solid var(--gold);
    padding: 1.15rem 1.35rem;
    border-radius: 4px;
  }

  .hero__quote p {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-style: italic;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.88);
    line-height: 1.6;
    max-width: none;
  }

  .hero__quote cite {
    display: block;
    margin-top: 0.4rem;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-style: normal;
    color: var(--gold);
    letter-spacing: 0.06em;
    font-weight: 500;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .hero__inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .hero__content {
      order: 1;
    }

    .hero__visual {
      order: 2;
      max-width: 560px;
    }

    .hero__stats {
      max-width: 480px;
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding-top: 5.5rem;
      min-height: auto;
    }

    .hero__visual {
      max-width: 100%;
    }

    .hero__photo {
      min-height: 280px;
      max-height: 360px;
    }

    .hero__quote p {
      font-size: 0.82rem;
    }

    .hero__stats {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      max-width: 320px;
    }

    .hero__stat:nth-child(1),
    .hero__stat:nth-child(2) {
      border-bottom: 1px solid rgba(181, 169, 154, 0.25);
    }

    .hero__stat:nth-child(2) {
      border-right: none;
    }

    .hero__stat:nth-child(4) {
      border-right: none;
    }
  }
</style>
