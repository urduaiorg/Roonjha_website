---
const platforms = [
  {
    emoji: '🤖',
    tag: 'AI Literacy',
    name: 'Urdu AI',
    description: 'Pakistan\'s leading Urdu-language AI education platform. Social media, newsletter, mobile app, and workshops reaching the largest Urdu AI community in the world.',
    stat: '1M+ reach',
    url: 'https://urduai.org',
    wide: false,
  },
  {
    emoji: '📡',
    tag: 'Digital Infrastructure',
    name: 'PakSpeed',
    description: 'Pakistan\'s first community-owned internet speed monitoring network. Real connectivity data for digital equity advocacy and ISP accountability.',
    stat: '15K+ tests Week 1',
    url: 'https://pakspeed.com',
    wide: false,
  },
  {
    emoji: '🎓',
    tag: 'AI in Education',
    name: 'AI for Edu',
    description: 'Canadian K-12 and post-secondary educator platform for AI integration. Curriculum support, institutional strategy, practical classroom guidance.',
    stat: null,
    url: 'https://aiforedu.ai',
    wide: false,
  },
  {
    emoji: '🏘️',
    tag: 'Community Development',
    name: 'WANG / WALI',
    description: 'Girls\' education, flood rehabilitation, digital literacy, and youth leadership in communities where the digital divide is a daily reality.',
    stat: 'Funded by ISOC, AVPN, Google.org',
    url: '#contact',
    wide: true,
  },
  {
    emoji: '🌐',
    tag: 'AI Media',
    name: 'AI Viewer',
    description: 'English-language AI news, tool breakdowns, and analysis for a global professional audience.',
    stat: null,
    url: 'https://aiviewer.com',
    wide: false,
  },
];
---

<section class="platforms section" id="platforms">
  <div class="platforms__inner container">
    <div class="platforms__header reveal">
      <div class="platforms__header-left">
        <span class="eyebrow">Ecosystem</span>
        <h2>Five platforms.<br /><em>One ecosystem.</em></h2>
      </div>
      <p class="platforms__header-intro">
        Each platform serves a different community, a different language, a different need. Together, they form a connected infrastructure for AI inclusion that spans two continents.
      </p>
    </div>

    <div class="platforms__grid reveal-stagger">
      {platforms.map((p) => (
        <a
          href={p.url}
          class={`platform-card reveal ${p.wide ? 'platform-card--wide' : ''}`}
          target={p.url.startsWith('http') ? '_blank' : undefined}
          rel={p.url.startsWith('http') ? 'noopener noreferrer' : undefined}
        >
          <div class="platform-card__top-border" aria-hidden="true"></div>
          <span class="platform-card__emoji" aria-hidden="true">{p.emoji}</span>
          <span class="platform-card__tag">{p.tag}</span>
          <h3 class="platform-card__name">{p.name}</h3>
          <p class="platform-card__desc">{p.description}</p>
          {p.stat && <span class="platform-card__stat">{p.stat}</span>}
          <span class="platform-card__link">
            {p.url.startsWith('http') ? p.url.replace('https://', '') : 'Get in touch'}
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M4 12l8-8M5 4h7v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .platforms {
    background: var(--paper);
  }

  .platforms__header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: end;
    margin-bottom: 3.5rem;
  }

  .platforms__header h2 em {
    font-style: italic;
    font-weight: 300;
  }

  .platforms__header-intro {
    font-size: 1.0625rem;
    line-height: 1.85;
    color: var(--muted);
  }

  .platforms__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  /* Card */
  .platform-card {
    position: relative;
    background: #fff;
    border: 1px solid rgba(181, 169, 154, 0.15);
    border-radius: var(--radius);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    transition: background 0.25s ease, border-color 0.25s ease;
    overflow: hidden;
  }

  .platform-card:hover {
    background: #fdfbf8;
    border-color: rgba(181, 169, 154, 0.3);
  }

  .platform-card__top-border {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--rust);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .platform-card:hover .platform-card__top-border {
    transform: scaleX(1);
  }

  .platform-card--wide {
    grid-column: span 2;
  }

  .platform-card__emoji {
    font-size: 1.75rem;
    line-height: 1;
    margin-bottom: 0.25rem;
  }

  .platform-card__tag {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
  }

  .platform-card__name {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--ink);
  }

  .platform-card__desc {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--muted);
    max-width: none;
  }

  .platform-card__stat {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--rust);
    margin-top: 0.25rem;
  }

  .platform-card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--rust);
    margin-top: auto;
    padding-top: 0.5rem;
    transition: gap 0.2s ease;
  }

  .platform-card:hover .platform-card__link {
    gap: 0.6rem;
  }

  @media (max-width: 1024px) {
    .platforms__header {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .platforms__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .platform-card--wide {
      grid-column: span 2;
    }
  }

  @media (max-width: 768px) {
    .platforms__grid {
      grid-template-columns: 1fr;
    }

    .platform-card--wide {
      grid-column: span 1;
    }
  }
</style>
