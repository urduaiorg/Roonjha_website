---
const navLinks = [
  { label: 'Story', href: '#story' },
  { label: 'Platforms', href: '#platforms' },
  { label: 'Partner', href: '#partner' },
  { label: 'Contact', href: '#contact' },
];
---

<nav class="nav" id="nav">
  <div class="nav__inner container">
    <a href="/" class="nav__wordmark">Qaisar Roonjha</a>
    <ul class="nav__links">
      {navLinks.map((link) => (
        <li><a href={link.href}>{link.label}</a></li>
      ))}
    </ul>
    <a href="#contact" class="btn btn-outline nav__cta">Work With Me</a>
  </div>
</nav>

<script>
  const nav = document.getElementById('nav');
  let scrolled = false;

  function onScroll() {
    const isScrolled = window.scrollY > 40;
    if (isScrolled !== scrolled) {
      scrolled = isScrolled;
      nav?.classList.toggle('nav--solid', isScrolled);
    }
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    padding: 1.25rem 0;
    transition: background 0.35s ease, padding 0.35s ease, backdrop-filter 0.35s ease;
  }

  .nav--solid {
    background: rgba(247, 243, 236, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding: 0.75rem 0;
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.05);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .nav__wordmark {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--ink);
    letter-spacing: -0.01em;
    flex-shrink: 0;
  }

  .nav__links {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .nav__links a {
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--muted);
    letter-spacing: 0.02em;
    transition: color 0.2s ease;
  }

  .nav__links a:hover {
    color: var(--ink);
  }

  .nav__cta {
    padding: 0.625rem 1.5rem;
    font-size: 0.8125rem;
  }

  @media (max-width: 768px) {
    .nav__links {
      display: none;
    }

    .nav__cta {
      padding: 0.5rem 1.25rem;
      font-size: 0.75rem;
    }
  }
</style>
