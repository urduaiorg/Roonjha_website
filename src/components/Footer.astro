---
const links = [
  { label: 'Urdu AI', href: 'https://urduai.org' },
  { label: 'PakSpeed', href: 'https://pakspeed.com' },
  { label: 'AI for Edu', href: 'https://aiforedu.ai' },
  { label: 'AI Viewer', href: 'https://aiviewer.com' },
  { label: 'Contact', href: '#contact' },
];
---

<footer class="footer">
  <div class="footer__inner container">
    <a href="/" class="footer__wordmark">Qaisar Roonjha</a>

    <nav class="footer__links" aria-label="Footer navigation">
      {links.map((link) => (
        <a
          href={link.href}
          target={link.href.startsWith('http') ? '_blank' : undefined}
          rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <p class="footer__copy">&copy; 2025 Qaisar Roonjha. All rights reserved.</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--deep);
    padding: 3rem 0;
  }

  .footer__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
  }

  .footer__wordmark {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.2);
    letter-spacing: -0.01em;
  }

  .footer__links {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .footer__links a {
    font-size: 0.8125rem;
    color: rgba(181, 169, 154, 0.5);
    transition: color 0.2s ease;
  }

  .footer__links a:hover {
    color: var(--gold);
  }

  .footer__copy {
    font-size: 0.75rem;
    color: rgba(181, 169, 154, 0.3);
    max-width: none;
  }
</style>
