---
const funders = [
  'U.S. State Department',
  'Gates Foundation',
  'Google.org',
  'Asian Development Bank',
  'Internet Society',
  'British Council',
  'AVPN',
  'Scottish Government',
];

const media = [
  'BBC',
  'VOA',
  'The Independent',
  'Express News',
  'ARY',
];
---

<section class="trust-bar">
  <div class="trust-bar__row">
    <span class="trust-bar__label">Recognised & funded by</span>
    <div class="trust-bar__track">
      <div class="trust-bar__marquee">
        {funders.map((name) => (
          <Fragment>
            <span class="trust-bar__name">{name}</span>
            <span class="trust-bar__dot" aria-hidden="true">&middot;</span>
          </Fragment>
        ))}
        {funders.map((name) => (
          <Fragment>
            <span class="trust-bar__name" aria-hidden="true">{name}</span>
            <span class="trust-bar__dot" aria-hidden="true">&middot;</span>
          </Fragment>
        ))}
      </div>
    </div>
  </div>
  <div class="trust-bar__divider"></div>
  <div class="trust-bar__row">
    <span class="trust-bar__label">Featured in</span>
    <div class="trust-bar__track">
      <div class="trust-bar__marquee trust-bar__marquee--slow">
        {media.map((name) => (
          <Fragment>
            <span class="trust-bar__name">{name}</span>
            <span class="trust-bar__dot" aria-hidden="true">&middot;</span>
          </Fragment>
        ))}
        {media.map((name) => (
          <Fragment>
            <span class="trust-bar__name" aria-hidden="true">{name}</span>
            <span class="trust-bar__dot" aria-hidden="true">&middot;</span>
          </Fragment>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .trust-bar {
    background: var(--deep);
    padding: 1.35rem 0;
    overflow: hidden;
  }

  .trust-bar__row {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding: 0.5rem clamp(1.25rem, 5vw, 6vw);
  }

  .trust-bar__divider {
    width: 100%;
    height: 1px;
    background: rgba(181, 169, 154, 0.08);
  }

  .trust-bar__label {
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(181, 169, 154, 0.4);
    flex-shrink: 0;
    min-width: 130px;
  }

  .trust-bar__track {
    overflow: hidden;
    flex: 1;
    mask-image: linear-gradient(90deg, transparent, black 8%, black 92%, transparent);
    -webkit-mask-image: linear-gradient(90deg, transparent, black 8%, black 92%, transparent);
  }

  .trust-bar__marquee {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    width: max-content;
    animation: marquee 30s linear infinite;
  }

  .trust-bar__marquee--slow {
    animation-duration: 22s;
  }

  .trust-bar__name {
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 400;
    color: rgba(181, 169, 154, 0.55);
    letter-spacing: 0.03em;
    white-space: nowrap;
    transition: color 0.25s ease;
  }

  .trust-bar__name:hover {
    color: var(--gold);
  }

  .trust-bar__dot {
    color: rgba(181, 169, 154, 0.25);
    font-size: 1rem;
    flex-shrink: 0;
    line-height: 1;
  }

  @media (max-width: 768px) {
    .trust-bar__row {
      gap: 1.25rem;
    }

    .trust-bar__label {
      font-size: 0.5625rem;
      min-width: 90px;
    }

    .trust-bar__name {
      font-size: 0.7rem;
    }
  }
</style>
