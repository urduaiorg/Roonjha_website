---
const partners = [
  'AVPN',
  'Google.org',
  'Internet Society',
  'Asian Development Bank',
  'British Council',
  'AI Opportunity Fund: Asia-Pacific',
];
---

<section class="trust-bar">
  <div class="trust-bar__inner container">
    <span class="trust-bar__label">Recognised & funded by</span>
    <div class="trust-bar__logos">
      {partners.map((name, i) => (
        <Fragment>
          <span class="trust-bar__name">{name}</span>
          {i < partners.length - 1 && <span class="trust-bar__sep" aria-hidden="true"></span>}
        </Fragment>
      ))}
    </div>
  </div>
</section>

<style>
  .trust-bar {
    background: var(--deep);
    padding: 1.5rem 0;
    overflow: hidden;
  }

  .trust-bar__inner {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    flex-wrap: wrap;
  }

  .trust-bar__label {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(181, 169, 154, 0.5);
    flex-shrink: 0;
  }

  .trust-bar__logos {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .trust-bar__name {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 400;
    color: rgba(181, 169, 154, 0.65);
    letter-spacing: 0.03em;
    transition: color 0.25s ease;
    white-space: nowrap;
  }

  .trust-bar__name:hover {
    color: var(--gold);
  }

  .trust-bar__sep {
    width: 1px;
    height: 14px;
    background: rgba(181, 169, 154, 0.2);
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .trust-bar__inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }

    .trust-bar__logos {
      gap: 1rem;
    }

    .trust-bar__sep {
      display: none;
    }

    .trust-bar__name {
      font-size: 0.75rem;
    }
  }
</style>
